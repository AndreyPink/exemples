generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Nanny {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String
  telegram        String?
  district        String
  languages       String
  experience      String
  childAges       String
  availability    String
  rate            Int
  photoUrl        String?
  description     String
  documentConsent Boolean  @default(false)
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ParentRequest {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String
  telegram        String?
  district        String
  childAge        String
  schedule        String
  liveIn          Boolean  @default(false)
  language        String
  budget          Int
  comment         String
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
